PORT=4000
NODE_ENV=production

# Database (MongoDB)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/kioskquiz

# Error Tracking (Sentry)
SENTRY_DSN=https://key@org.ingest.sentry.io/project

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# DeepL (auto-translation)
DEEPL_API_KEY=your-deepl-key

# Admin PIN (required for moderator access)
ADMIN_PIN=2506

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# Optional: Single session mode
SINGLE_SESSION_MODE=false
SINGLE_SESSION_ROOM_CODE=MAIN

# Debug flags (development only)
POTATO_AUTOPILOT=false
POTATO_TIMEOUT_AUTOSTRIKE=false
