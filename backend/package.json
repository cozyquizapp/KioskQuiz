{
  "name": "quiz-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/backend/src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/backend/src/server.js",
    "recover:drafts": "node scripts/recover-cozy-drafts.js",
    "recover:drafts:apply": "node scripts/recover-cozy-drafts.js --apply"
  },
  "dependencies": {
    "@sentry/node": "^7.57.0",
    "cloudinary": "^2.6.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.2.4",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "quiz-monorepo": "file:..",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.19",
    "@types/uuid": "^9.0.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
