{
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "header", "key": "accept", "value": ".*text/html.*" }],
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cozyquiz-backend.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://cozyquiz-backend.onrender.com/socket.io/:path*"
    },
    {
      "source": "/grid-demo.html",
      "destination": "/grid-demo.html"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}
